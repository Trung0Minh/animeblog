generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  username      String    @unique
  passwordHash  String?
  bio           String?   @db.Text
  avatarUrl     String?
  emailVerified DateTime?
  image         String?
  role          Role      @default(WRITER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  posts           Post[]               @relation("PostPrimaryAuthor")
  coAuthoredPosts PostAuthor[]
  accounts        Account[]
  sessions        Session[]
  invitesSent     Invite[]             @relation("InviteCreatedBy")
  passwordResets  PasswordResetToken[]

  @@index([username])
  @@index([role, createdAt(sort: Desc)])
  @@index([role, name])
  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

enum Role {
  WRITER
  ADMIN
  REVOKED
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Invite {
  id          String       @id @default(cuid())
  email       String
  token       String       @unique @default(cuid())
  status      InviteStatus @default(PENDING)
  expiresAt   DateTime
  createdAt   DateTime     @default(now())
  createdById String

  createdBy User @relation("InviteCreatedBy", fields: [createdById], references: [id])

  @@index([token])
  @@index([email])
  @@index([status, expiresAt, createdAt(sort: Desc)])
  @@map("invites")
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

model Post {
  id              String                   @id @default(cuid())
  title           String
  slug            String                   @unique
  excerpt         String?                  @db.Text
  coverUrl        String?
  coverAlt        String?
  content         Json
  contentText     String?                  @db.Text
  status          PostStatus               @default(DRAFT)
  draftVisibility DraftVisibility          @default(PRIVATE)
  publishedAt     DateTime?
  lastSavedAt     DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  authorId        String
  author          User                     @relation("PostPrimaryAuthor", fields: [authorId], references: [id])
  coAuthors       PostAuthor[]
  categoryId      String?
  category        Category?                @relation(fields: [categoryId], references: [id])
  tags            PostTag[]
  comments        Comment[]
  searchVector    Unsupported("tsvector")? @map("search_vector")

  @@index([slug])
  @@index([status, publishedAt(sort: Desc)])
  @@index([authorId])
  @@index([categoryId])
  @@index([categoryId, status, publishedAt(sort: Desc), updatedAt(sort: Desc)])
  @@index([authorId, status, publishedAt(sort: Desc), updatedAt(sort: Desc)])
  @@index([authorId, status, updatedAt(sort: Desc)])
  @@map("posts")
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum DraftVisibility {
  PRIVATE
  CO_AUTHORS
}

model PostAuthor {
  postId String
  userId String
  order  Int    @default(0)

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
  @@index([userId])
  @@map("post_authors")
}

model Category {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?    @db.Text
  parentId    String?
  createdAt   DateTime   @default(now())
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  posts       Post[]

  @@index([slug])
  @@index([parentId, name])
  @@map("categories")
}

model Tag {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  createdAt DateTime  @default(now())
  posts     PostTag[]

  @@index([slug])
  @@map("tags")
}

model PostTag {
  postId String
  tagId  String

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
  @@map("post_tags")
}

model Comment {
  id          String        @id @default(cuid())
  postId      String
  parentId    String?
  authorName  String
  authorEmail String
  content     String        @db.Text
  status      CommentStatus @default(APPROVED)
  notifyReply Boolean       @default(true)
  createdAt   DateTime      @default(now())
  post        Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent      Comment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies     Comment[]     @relation("CommentReplies")

  @@index([postId, status])
  @@index([parentId])
  @@index([status, createdAt(sort: Desc)])
  @@map("comments")
}

enum CommentStatus {
  APPROVED
  SPAM
}

model NewsletterSubscriber {
  id             String           @id @default(cuid())
  email          String           @unique
  status         SubscriberStatus @default(ACTIVE)
  token          String           @unique @default(cuid())
  subscribedAt   DateTime         @default(now())
  unsubscribedAt DateTime?

  @@index([email])
  @@index([token])
  @@index([status])
  @@map("newsletter_subscribers")
}

enum SubscriberStatus {
  ACTIVE
  UNSUBSCRIBED
}

enum AnalyticsEventType {
  PAGE_VIEW
  POST_READ
  COMMENT_SUBMITTED
  NEWSLETTER_SUBSCRIBED
  SEARCH_PERFORMED
}

model AnalyticsEvent {
  id              String             @id @default(cuid())
  type            AnalyticsEventType
  path            String?
  postSlug        String?
  searchQuery     String?
  visitorHash     String?
  sessionHash     String?
  durationSeconds Int?
  createdAt       DateTime           @default(now())

  @@index([type, createdAt(sort: Desc)])
  @@index([path, createdAt(sort: Desc)])
  @@index([postSlug, type, createdAt(sort: Desc)])
  @@index([visitorHash, createdAt(sort: Desc)])
  @@map("analytics_events")
}

model AnalyticsDailySummary {
  id                String   @id @default(cuid())
  day               DateTime @db.Date
  pageviews         Int      @default(0)
  visitors          Int      @default(0)
  sessions          Int      @default(0)
  reads             Int      @default(0)
  comments          Int      @default(0)
  newsletterSignups Int      @default(0)
  searches          Int      @default(0)
  totalReadSeconds  Int      @default(0)
  updatedAt         DateTime @updatedAt

  @@unique([day])
  @@index([day])
  @@map("analytics_daily_summaries")
}

model AnalyticsDailyPage {
  id           String    @id @default(cuid())
  day          DateTime  @db.Date
  path         String
  postSlug     String?
  pageviews    Int       @default(0)
  reads        Int       @default(0)
  comments     Int       @default(0)
  lastViewedAt DateTime?
  updatedAt    DateTime  @updatedAt

  @@unique([day, path])
  @@index([path, day(sort: Desc)])
  @@index([postSlug, day(sort: Desc)])
  @@index([day, pageviews(sort: Desc)])
  @@map("analytics_daily_pages")
}

model AnalyticsDailyVisitor {
  id          String   @id @default(cuid())
  day         DateTime @db.Date
  visitorHash String
  createdAt   DateTime @default(now())

  @@unique([day, visitorHash])
  @@map("analytics_daily_visitors")
}

model AnalyticsDailySession {
  id          String   @id @default(cuid())
  day         DateTime @db.Date
  sessionHash String
  createdAt   DateTime @default(now())

  @@unique([day, sessionHash])
  @@map("analytics_daily_sessions")
}

model SitePage {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  content     Json
  contentText String?  @db.Text
  updatedAt   DateTime @updatedAt

  @@map("site_pages")
}
